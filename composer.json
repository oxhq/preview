{
    "name": "oxhq/preview",
    "description": "Laravel-native capture, replay, fixture, and test generation for real application flows.",
    "homepage": "https://github.com/oxhq/preview",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "capture",
        "flow-replay",
        "fixtures",
        "laravel",
        "preview",
        "replay",
        "testing"
    ],
    "authors": [
        {
            "name": "oxhq",
            "homepage": "https://github.com/oxhq",
            "role": "Maintainer"
        }
    ],
    "support": {
        "issues": "https://github.com/oxhq/preview/issues",
        "source": "https://github.com/oxhq/preview",
        "docs": "https://github.com/oxhq/preview#readme"
    },
    "require": {
        "php": "^8.3",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/filesystem": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "symfony/process": "^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Oxhq\\Preview\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Oxhq\\Preview\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Oxhq\\Preview\\PreviewServiceProvider"
            ]
        }
    },
    "archive": {
        "exclude": [
            "/.github",
            "/.gitattributes",
            "/.gitignore",
            "/.phpunit.result.cache",
            "/.preview-internal",
            "/phpunit.xml",
            "/tests"
        ]
    },
    "scripts": {
        "ci": [
            "composer validate --strict",
            "php scripts/check-release-surface.php",
            "php scripts/check-command-surface.php",
            "php scripts/check-public-surface.php",
            "phpunit"
        ],
        "release:dist": "php scripts/check-dist-archive.php",
        "release:github": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-github-release.ps1",
        "release:packagist": "php scripts/check-packagist.php",
        "release:prepare": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/prepare-release.ps1",
        "release:check": "php scripts/check-release-surface.php",
        "release:commands": "php scripts/check-command-surface.php",
        "release:powershell": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/check-powershell-surface.ps1",
        "release:public-surface": "php scripts/check-public-surface.php",
        "release:source": "php scripts/check-source-archive.php",
        "smoke:cloudflared": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-tunnel.ps1 -Transport cloudflare",
        "smoke:consumer": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-consumer.ps1",
        "smoke:github-webhook": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-github-webhook.ps1",
        "smoke:ingress": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-public-ingress.ps1",
        "smoke:packagist-install": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-packagist-install.ps1",
        "smoke:provider-signatures": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-provider-signatures.ps1",
        "smoke:stripe-cli": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-stripe-cli.ps1",
        "smoke:tunnel": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/smoke-tunnel.ps1",
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
